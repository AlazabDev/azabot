# AzaBot Frontend - public browser variables only
# Keep production .env files outside GitHub.

VITE_CHAT_API_URL=
VITE_SITE_ID=

# Public Supabase settings used only for public bot settings/realtime UI.
# Do not place service_role keys here.
VITE_SUPABASE_PROJECT_ID=
